# Cronmanager Web App base URL (no trailing slash)
CM_BASE_URL=https://cronmanager.example.com

# API key generated in the Cronmanager web UI (API Keys section)
# The key must have the scopes required for the tools you intend to use.
CM_API_KEY=cm_your_api_key_here

# Optional: restrict requests to a specific agent in a multi-agent setup
# CM_AGENT_ID=1

# Bearer token protecting this MCP server's HTTP endpoint
MCP_AUTH_TOKEN=your_mcp_auth_token_here

# HTTP port (default: 3000)
# PORT=3000

# API request timeout in milliseconds (default: 10000)
# TIMEOUT_MS=10000

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Restrict to read-only tools at startup (default: false)
# When true, only tools requiring jobs:read, export:read, maintenance:read,
# and settings:read scopes are registered.
# MCP_READONLY_MODE=false
