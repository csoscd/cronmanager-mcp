# Cronmanager Web URL
# If this container runs in the same Docker network as the Cronmanager web
# container, you can use the internal service name:
#   CM_BASE_URL=http://cronmanager-web:8080
# Otherwise use the public URL:
CM_BASE_URL=https://cronmanager.example.com

# API key generated in the Cronmanager web UI (API Keys section).
# The key must have the scopes required for the tools you intend to use.
# Recommended: jobs:read, jobs:write, jobs:execute, export:read,
#              maintenance:read, maintenance:write, settings:read
CM_API_KEY=cm_your_api_key_here

# Bearer token protecting this MCP server's HTTP endpoint.
# Choose a long random string (e.g. openssl rand -hex 32).
MCP_AUTH_TOKEN=your_mcp_auth_token_here

# Optional: target a specific agent in a multi-agent Cronmanager setup.
# Sets the X-Agent-Id request header.
# CM_AGENT_ID=1

# HTTP port the MCP server listens on (default: 3000)
# PORT=3000

# Cronmanager API request timeout in milliseconds (default: 10000)
# TIMEOUT_MS=10000

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Set to true to register only read-only tools at startup (default: false).
# Useful for setups where the API key only has read scopes.
# MCP_READONLY_MODE=false
